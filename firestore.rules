rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any authenticated user can read profiles (needed for public boards)
      allow read: if request.auth != null;

      // Only the owner can create / update their profile
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;

      // Only the owner can delete their account document
      allow delete: if request.auth != null && request.auth.uid == uid;

      // ── Favorites subcollection ───────────────────────────────────────────
      match /favorites/{favoriteId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Usernames (uniqueness registry) ──────────────────────────────────────
    // doc id = username, data = { uid: string }
    match /usernames/{username} {
      allow read: if request.auth != null;
      // Anyone can claim a username (batch write during profile creation)
      allow create: if request.auth != null;
      // Only the user who claimed it can release it (account deletion)
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // ── Comments (anonymous board messages) ───────────────────────────────────
    match /comments/{commentId} {
      // Only the board owner can read their own comments
      allow read: if request.auth != null
                  && resource.data.boardOwnerId == request.auth.uid;

      // Any authenticated user may write an anonymous comment
      allow create: if request.auth != null
                    && request.resource.data.boardOwnerId is string
                    && request.resource.data.boardOwnerId.size() > 0
                    && request.resource.data.text is string
                    && request.resource.data.text.size() >= 1
                    && request.resource.data.text.size() <= 500;

      // Board owner can update (mark read, toggle reactions) or delete
      allow update: if request.auth != null
                    && resource.data.boardOwnerId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.boardOwnerId == request.auth.uid;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // admin SDK only
    }
  }
}
