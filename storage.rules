rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatars ───────────────────────────────────────────────────────────────
    // Path: avatars/{userId}/avatar.jpg  (or any file under their folder)
    match /avatars/{userId}/{allPaths=**} {
      // Any authenticated user can view avatars (shown in public profiles)
      allow read: if request.auth != null;

      // Only the owner can upload/replace/delete their own avatar
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 5 * 1024 * 1024   // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
